rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Selección de sedes por usuario
    match /sedes_seleccion_user/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Configuración por usuario - cada uno solo su documento
    match /config_usuarios/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Compatibilidad temporal con la colección antigua
    match /usuarios/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Solo usuarios autenticados pueden acceder
    match /cargues_descargues/{document} {
      allow create, read, update, delete: if request.auth != null;
    }

    match /aperturas_seguridad/{document} {
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && 
                                      resource.data.userId == request.auth.uid;
    }
  }
}