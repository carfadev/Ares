rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      let doc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return doc.exists ? doc.data.role : 'vigilante';
    }

    function isRole(role) {
      return isAuth() && getUserRole() == role;
    }

    function hasAnyRole(roles) {
      return isAuth() && getUserRole() in roles;
    }

    function isAdmin() {
      return isRole('admin');
    }

    function isAdminOrSupervisor() {
      return hasAnyRole(['admin', 'supervisor']);
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function hasAuditFields() {
      return request.resource.data.keys().hasAll(['createdBy', 'createdAt', 'userId']);
    }

    match /sedes_seleccion_user/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /config_usuarios/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /usuarios/{userId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /cargues_descargues/{document} {
      allow create: if isAuth() && isRole('vigilante') && hasAuditFields();
      allow read: if isAuth();
      allow update: if isAuth() && (isOwner(resource.data.userId) || isAdminOrSupervisor());
      allow delete: if isAdmin();
    }

    match /aperturas_seguridad/{document} {
      allow create: if isAuth() && isRole('vigilante') && hasAuditFields();
      allow read: if isAuth();
      allow update: if isAuth() && (isOwner(resource.data.userId) || isAdminOrSupervisor());
      allow delete: if isAdmin();
    }

    match /novedades/{document} {
      allow create: if isAuth() && isRole('vigilante') && hasAuditFields();
      allow read: if isAuth();
      allow update: if isAuth() && (isOwner(resource.data.userId) || isAdminOrSupervisor());
      allow delete: if isAdmin();
    }
  }
}
