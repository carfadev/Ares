---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { clientConfig } from '../../client.config';
---

<BaseLayout title="ARES" description="Ingreso al sistema de reportes operacionales" showHeader={false}>
  <div class="relative min-h-screen overflow-hidden text-slate-900" style={`background: ${clientConfig.colors.neutroClaro}`}>
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute left-1/2 -top-28 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(249,126,5,0.08)_0%,rgba(249,126,5,0)_70%)] blur-3xl"></div>
      <div class="absolute -bottom-28 -right-20 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(12,60,107,0.08)_0%,rgba(12,60,107,0)_68%)] blur-3xl"></div>
    </div>

    <main class="relative z-10 flex min-h-screen items-center justify-center px-6 py-10 sm:px-8">
      <section class="w-full max-w-107.5 text-center -mt-8 sm:-mt-12">
        <div class="flex flex-col items-center">
          <img src={clientConfig.logo} alt={clientConfig.appName} class="h-20 w-20 object-contain" />

          <h1 class="mt-4 text-4xl font-light tracking-normal text-slate-800 sm:text-5xl">ARES</h1>
          <p class="mt-1 text-[11px] font-semibold uppercase tracking-[0.28em] text-slate-400 sm:text-xs">Aplicación de Reportes y Evidencias de Seguridad</p>

          <div class="mt-6 h-px w-12 bg-[linear-gradient(90deg,transparent,rgba(249,126,5,0.95),transparent)]"></div>

          <!-- <p class="mt-6 text-sm leading-6 text-slate-600 sm:text-[15px]">
            Aplicación oficial del
            <span class="block font-semibold text-slate-800">Departamento de Asuntos de Seguridad</span>
          </p> -->
        </div>

        <div class="mt-12 text-left">
          <p class="text-sm font-medium text-slate-700 sm:text-base">Inicia sesión para continuar</p>
          <form class="mt-6 space-y-5" action="#" method="post">
            <label class="block">
              <span class="sr-only">Correo electrónico</span>
              <div class="w-full relative">
                <div class="w-full flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm transition focus-within:border-slate-300 focus-within:ring-2 focus-within:ring-[rgba(12,60,107,0.16)]">
                  <svg aria-hidden="true" class="h-5 w-5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="14" x="3" y="5" rx="2" />
                    <path d="m3 7 9 6 9-6" />
                  </svg>
                  <input
                    type="email"
                    name="email"
                    autocomplete="email"
                    placeholder="Correo electrónico"
                    class="w-full border-0 bg-transparent text-sm text-slate-900 outline-none placeholder:text-slate-400 sm:text-[15px] pr-10"
                  />
                </div>
              </div>
            </label>

            <label class="block">
              <span class="sr-only">Contraseña</span>
              <div class="w-full relative">
                <div class="w-full flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-sm transition focus-within:border-slate-300 focus-within:ring-2 focus-within:ring-[rgba(12,60,107,0.16)]">
                  <svg aria-hidden="true" class="h-5 w-5 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="16" height="10" x="4" y="11" rx="2" />
                    <path d="M8 11V8a4 4 0 1 1 8 0v3" />
                  </svg>
                  <input
                    type="password"
                    name="password"
                    autocomplete="current-password"
                    placeholder="Contraseña"
                    class="w-full border-0 bg-transparent text-sm text-slate-900 outline-none placeholder:text-slate-400 sm:text-[15px] pr-10"
                  />
                </div>
                <button type="button" class="absolute right-4 top-1/2 -translate-y-1/2 inline-flex h-8 w-8 items-center justify-center rounded-full text-slate-400 transition hover:bg-slate-100 hover:text-slate-600" aria-label="Mostrar contraseña">
                  <svg aria-hidden="true" class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2.1 12s3.4-6.9 9.9-6.9S22 12 22 12s-3.4 6.9-9.9 6.9S2.1 12 2.1 12Z" />
                    <circle cx="12" cy="12" r="3" />
                  </svg>
                </button>
              </div>
            </label>

            <div class="flex items-center justify-between gap-4 pt-1 text-sm">
              <label class="inline-flex items-center gap-2 text-slate-500">
                <input type="checkbox" name="remember" class="h-4 w-4 rounded border-slate-300 text-[rgb(12,60,107)] focus:ring-[rgba(12,60,107,0.18)]" />
                <span>Recordarme</span>
              </label>
              <a href="#" class="font-medium text-[rgb(12,60,107)] transition hover:text-[rgb(9,46,82)]">¿Olvidaste tu contraseña?</a>
            </div>

            <button
                type="button"
                class="group inline-flex w-full items-center justify-center gap-3 rounded-xl bg-[linear-gradient(180deg,#0c3c6b_0%,#092b4d_100%)] px-5 py-3 text-sm font-semibold text-white shadow-[0_12px_24px_rgba(12,60,107,0.18)] transition hover:-translate-y-0.5 hover:shadow-[0_18px_30px_rgba(12,60,107,0.24)] focus:outline-none focus:ring-2 focus:ring-[rgba(249,126,5,0.35)] focus:ring-offset-2 focus:ring-offset-white"
            >
              Iniciar sesión
              <svg aria-hidden="true" class="h-4 w-4 text-[rgb(249,126,5)] transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" />
                <path d="m13 5 7 7-7 7" />
              </svg>
            </button>
          </form>

          

          <div class="mt-7 flex items-center justify-center gap-3 text-left">
            <img src="/images/das.png" alt={clientConfig.appName} class="h-9 w-9 sm:h-10 sm:w-10 object-contain" />
            <p class="text-xs leading-5 text-slate-500 sm:text-sm">
              Aplicación oficial del
              <span class="block font-medium text-slate-700">Departamento de Asuntos de Seguridad</span>
            </p>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
