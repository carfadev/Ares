---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { clientConfig } from '../../client.config';
import LoginForm from '../islands/LoginForm.jsx';

const nextPath = Astro.url.searchParams.get('next') || '/';
---

<BaseLayout title="ARES" description="Ingreso al sistema de reportes operacionales" showHeader={false}>
  <div class="relative min-h-screen overflow-hidden text-slate-900" style={`background: ${clientConfig.colors.neutroClaro}`}>
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="absolute left-1/2 -top-28 h-64 w-64 -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(249,126,5,0.08)_0%,rgba(249,126,5,0)_70%)] blur-3xl"></div>
      <div class="absolute -bottom-28 -right-20 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(12,60,107,0.08)_0%,rgba(12,60,107,0)_68%)] blur-3xl"></div>
    </div>

    <main class="relative z-10 flex min-h-screen items-center justify-center px-6 py-10 sm:px-8">
      <section class="w-full max-w-107.5 text-center -mt-8 sm:-mt-12">
        <div class="flex flex-col items-center">
          <img src={clientConfig.logo} alt={clientConfig.appName} class="h-20 w-20 object-contain" />

          <h1 class="mt-4 text-4xl font-light tracking-normal text-slate-800 sm:text-5xl">ARES</h1>
          <p class="mt-1 text-[11px] font-semibold uppercase tracking-[0.28em] text-slate-400 sm:text-xs">Aplicación de Reportes y Evidencias de Seguridad</p>

          <div class="mt-6 h-px w-12 bg-[linear-gradient(90deg,transparent,rgba(249,126,5,0.95),transparent)]"></div>

          <!-- <p class="mt-6 text-sm leading-6 text-slate-600 sm:text-[15px]">
            Aplicación oficial del
            <span class="block font-semibold text-slate-800">Departamento de Asuntos de Seguridad</span>
          </p> -->
        </div>

        <div class="mt-12 text-left">
          <p class="text-sm font-medium text-slate-700 sm:text-base">Inicia sesión para continuar</p>
          <LoginForm client:load nextPath={nextPath} />

          

          <div class="mt-7 flex items-center justify-center gap-3 text-left">
            <img src="/images/das.png" alt={clientConfig.appName} class="h-9 w-9 sm:h-10 sm:w-10 object-contain" />
            <p class="text-xs leading-5 text-slate-500 sm:text-sm">
              Aplicación oficial del
              <span class="block font-medium text-slate-700">Departamento de Asuntos de Seguridad</span>
            </p>
          </div>
        </div>
      </section>
    </main>
  </div>

</BaseLayout>
