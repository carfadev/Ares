---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Ares — Panel">
  <div class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200">
      <div class="mx-auto max-w-5xl px-6 py-5 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/apple-touch-icon.png" alt="Ares" class="h-10 w-10 rounded-md" />
          <div>
            <p class="text-sm font-semibold tracking-wide text-slate-700">Ares</p>
            <p class="text-xs text-slate-500">Reportes de operaciones logísticas</p>
          </div>
        </div>
        <nav aria-label="acciones">
          <a class="text-sm text-slate-600 hover:text-slate-800" href="#">Acceder</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-6 py-12">
      <section class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Inicio</h1>
        <p class="mt-2 text-sm text-slate-600">Panel minimalista para gestión y reportes.</p>
      </section>

      <section aria-label="panel principal" class="grid grid-cols-1 gap-6 sm:grid-cols-3">
        <a href="/operaciones" class="group rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md hover:border-slate-300 focus:outline-none focus:ring-2 focus:ring-cyan-500">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-slate-100 text-slate-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-truck">
                <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/>
                <path d="M15 18H9"/>
                <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/>
                <circle cx="17" cy="18" r="2"/>
                <circle cx="7" cy="18" r="2"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Operaciones</h2>
              <p class="mt-1 text-sm text-slate-600">Reportes y seguimiento de cargas.</p>
            </div>
          </div>
        </a>

        <article class="group rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-slate-100 text-slate-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lock-open">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Aperturas</h2>
              <p class="mt-1 text-sm text-slate-600">Registro de aperturas y accesos.</p>
            </div>
          </div>
        </article>

        <article class="group rounded-lg border border-slate-200 bg-white p-5 shadow-sm transition hover:shadow-md">
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-slate-100 text-slate-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-siren">
                <path d="M7 18v-6a5 5 0 1 1 10 0v6"/>
                <path d="M5 21a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-1a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2z"/>
                <path d="M21 12h1"/>
                <path d="M18.5 4.5 18 5"/>
                <path d="M2 12h1"/>
                <path d="M12 2v1"/>
                <path d="m4.929 4.929.707.707"/>
                <path d="M12 12v6"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-slate-900">Novedades</h2>
              <p class="mt-1 text-sm text-slate-600">Alertas y novedades operativas.</p>
            </div>
          </div>
        </article>
      </section>
    </main>
  </div>
</BaseLayout>
