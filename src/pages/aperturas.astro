---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import AperturasForm from '../islands/AperturasForm.jsx';
---

<BaseLayout title="Aperturas — Ares">
  <div class="min-h-screen text-slate-900">
    <main class="mx-auto max-w-5xl px-4 pb-10 pt-24 sm:px-6 sm:pb-12 sm:pt-28">
      <div class="mb-5 flex flex-col gap-3 sm:mb-6 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <a href="/" class="text-sm font-medium text-cyan-700 hover:text-cyan-900">Volver al inicio</a>
      </div>
      <AperturasForm client:load />
    </main>
  </div>
</BaseLayout>