---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import OperacionesForm from '../islands/OperacionesForm.jsx';
---

<BaseLayout title="Operaciones — Ares">
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-10 lg:py-12">
      <div class="mb-5 flex flex-col gap-3 sm:mb-6 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <div>
          <h1 class="text-xl font-bold sm:text-2xl">Operaciones</h1>
          <p class="text-sm text-slate-600">Aquí se registran los cargues y descargues.</p>
        </div>
        <a href="/" class="text-sm font-medium text-cyan-700 hover:text-cyan-900">Volver al inicio</a>
      </div>
      <OperacionesForm client:visible />
    </main>
  </div>
</BaseLayout>
