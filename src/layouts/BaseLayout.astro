---
interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
}

import { clientConfig } from '../../client.config';
import ToastBridge from '../islands/ToastBridge.jsx';
import AuthGate from '../islands/AuthGate.jsx';
import UserMenu from '../islands/UserMenu.jsx';
import SedeDisplay from '../islands/SedeDisplay.jsx';
import SedeSelectionModal from '../islands/SedeSelectionModal.jsx';
import SkeletonLoader from '../islands/SkeletonLoader.jsx';
import SessionManager from '../islands/SessionManager.jsx';

const { title, description, showHeader = true } = Astro.props;
const isLoginPage = Astro.url.pathname === '/login';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#020617" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <script type="module" src="/registerSW.js"></script>
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <script is:inline>
      window.getGreetingMessage = function getGreetingMessage() {
        const currentHour = new Date().getHours();

        if (currentHour >= 0 && currentHour < 12) {
          return 'Buenos días';
        }

        if (currentHour >= 12 && currentHour < 19) {
          return 'Buenas tardes';
        }

        return 'Buenas noches';
      };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  </head>
  <body style={`background: ${clientConfig.colors.neutroClaro}`}>
    {showHeader && (
      <header
        class="fixed left-1/2 top-4 z-50 w-[calc(100%-1.5rem)] max-w-5xl -translate-x-1/2 overflow-visible rounded-full border border-white/45 bg-white/30 shadow-[0_12px_40px_rgba(15,23,42,0.18)] backdrop-blur-2xl"
        style="backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%);"
      >
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 overflow-hidden rounded-full"
          style="background: linear-gradient(to bottom, rgba(255,255,255,0.7), rgba(255,255,255,0.35), rgba(255,255,255,0.15));"
        ></div>
        <div class="relative z-10 mx-auto flex items-center justify-between px-6 py-2.5">
          <a href="/" class="flex items-center gap-3" aria-label="Ir al inicio">
            <img src={clientConfig.logo} alt={clientConfig.appName} class="h-10 w-10 rounded-md" />
            <p class="text-sm font-semibold tracking-wide text-slate-700">{clientConfig.appName}</p>
          </a>
          <div class="flex items-center gap-4">
            <SedeDisplay client:load />
            <nav aria-label="acciones">
              <UserMenu client:load />
            </nav>
          </div>
        </div>
      </header>
    )}
    <SessionManager client:load />
    <ToastBridge client:load />
    {!isLoginPage && <SkeletonLoader client:load />}
    {!isLoginPage && <SedeSelectionModal client:load />}
    <div id="main-content"><slot /></div>
    <AuthGate client:load />

    <script is:inline>
      function updateGreetingMessage() {
        const el = document.querySelector('[data-greeting-message]');
        if (el && typeof window.getGreetingMessage === 'function') {
          el.textContent = window.getGreetingMessage();
        }
      }

      async function loadPage(url) {
        try {
          const resp = await fetch(url);
          const html = await resp.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const mainContent = doc.querySelector('#main-content');

          // Pre-load module scripts for new islands
          const scripts = doc.querySelectorAll('script[type="module"]');
          await Promise.all(
            Array.from(scripts)
              .filter(s => s.src && s.src.startsWith(window.location.origin))
              .map(s => import(s.src).catch(() => {}))
          );

          const container = document.getElementById('main-content');
          if (container && mainContent) {
            container.innerHTML = mainContent.innerHTML;
          }

          document.title = doc.title;
          window.scrollTo(0, 0);
          attachNavigationListeners();
        } catch (e) {
          console.error('SPA navigation failed, falling back to full load', e);
          window.location.href = url;
        }
      }

      function attachNavigationListeners() {
        document.querySelectorAll('a').forEach(link => {
          const href = link.getAttribute('href');
          if (href && !href.startsWith('http') && !href.startsWith('#') && !href.startsWith('mailto:')) {
            link.addEventListener('click', (e) => {
              e.preventDefault();
              window.history.pushState(null, '', href);
              loadPage(href);
            });
          }
        });
      }

      attachNavigationListeners();
      updateGreetingMessage();

      window.addEventListener('popstate', () => {
        loadPage(window.location.pathname);
      });
    </script>
  </body>
</html>
