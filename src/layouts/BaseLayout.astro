---
interface Props {
  title: string;
  description?: string;
}

import { clientConfig } from '../../client.config';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#020617" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body style={`background: ${clientConfig.colors.neutroClaro}`}>
    <header
      class="fixed left-1/2 top-4 z-50 w-[calc(100%-1.5rem)] max-w-5xl -translate-x-1/2 overflow-hidden rounded-full border border-white/45 bg-white/30 shadow-[0_12px_40px_rgba(15,23,42,0.18)] backdrop-blur-2xl"
      style="backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%);"
    >
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-gradient-to-b from-white/70 via-white/35 to-white/15"></div>
      <div class="relative z-10 mx-auto flex items-center justify-between px-6 py-2.5">
        <a href="/" class="flex items-center gap-3" aria-label="Ir al inicio">
          <img src={clientConfig.logo} alt={clientConfig.appName} class="h-10 w-10 rounded-md" />
          <p class="text-sm font-semibold tracking-wide text-slate-700">{clientConfig.appName}</p>
        </a>
        <nav aria-label="acciones">
          <a class="inline-flex items-center justify-center text-slate-600 transition hover:text-slate-800" href="#" aria-label="Acceder">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-round-icon lucide-user-round">
              <circle cx="12" cy="8" r="5" />
              <path d="M20 21a8 8 0 0 0-16 0" />
            </svg>
          </a>
        </nav>
      </div>
    </header>
    <slot />
    <script type="module">
      // SPA Navigation with view transitions
      const pageContent = document.body;

      function updateGreetingMessage() {
        const greetingMessage = document.querySelector('[data-greeting-message]');

        if (!greetingMessage) return;

        const currentHour = new Date().getHours();
        let greeting = 'Buenas noches';

        if (currentHour >= 0 && currentHour < 12) {
          greeting = 'Buenos días';
        } else if (currentHour >= 12 && currentHour < 19) {
          greeting = 'Buenas tardes';
        }

        greetingMessage.textContent = greeting;
      }
      
      async function loadPage(url) {
        try {
          const response = await fetch(url);
          const html = await response.text();
          
          // Parse the response to get the body content
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newContent = doc.body;
          
          // Fade out transition
          pageContent.style.opacity = '0.7';
          pageContent.style.transition = 'opacity 0.2s ease-in-out';
          
          // Update content
          setTimeout(() => {
            pageContent.innerHTML = newContent.innerHTML;
            pageContent.style.opacity = '1';
            
            // Re-attach event listeners
            attachNavigationListeners();
            updateGreetingMessage();
            
            // Update page title
            document.title = doc.title;
            
            // Scroll to top
            window.scrollTo(0, 0);
          }, 200);
        } catch (error) {
          console.error('Failed to load page:', error);
          window.location.href = url;
        }
      }
      
      function attachNavigationListeners() {
        document.querySelectorAll('a').forEach(link => {
          const href = link.getAttribute('href');
          if (href && !href.startsWith('http') && !href.startsWith('#') && !href.startsWith('mailto:')) {
            link.addEventListener('click', (e) => {
              e.preventDefault();
              window.history.pushState(null, '', href);
              loadPage(href);
            });
          }
        });
      }
      
      // Initial setup
      attachNavigationListeners();
      updateGreetingMessage();
      
      // Handle back button
      window.addEventListener('popstate', () => {
        loadPage(window.location.pathname);
      });
    </script>
  </body>
</html>
